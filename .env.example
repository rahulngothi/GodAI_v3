# --- Dharma AI environment (copy to .env and fill in) ---

# NVIDIA API — serves Kimi K2.6 chat + nv-embedqa embeddings
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=moonshotai/kimi-k2.6
EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# MongoDB
# Local dev: localhost. In Docker, docker-compose overrides this to the mongo service.
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=dharma_ai

# Server
API_HOST=0.0.0.0
API_PORT=8080
